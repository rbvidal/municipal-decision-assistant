# Municipal Decision Assistant — Environment Configuration
# Copy this file to .env and fill in the values for your deployment.
# .env is ignored by git — never commit real secrets.

# ── Required: Authentication ──
# HMAC-SHA256 JWT signing secret (≥32 characters for HS256)
AUTH_JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
AUTH_JWT_ISSUER=municipal-decision-assistant
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=30d

# ── Required: Database ──
DB_NAME=municipal_decision_assistant
DB_URL=jdbc:postgresql://localhost:5432/municipal_decision_assistant
DB_USERNAME=platform
DB_PASSWORD=change-me

# ── Required: Qdrant Vector Database ──
QDRANT_HOST=localhost
QDRANT_REST_PORT=6333
QDRANT_COLLECTION=mda_chunks
QDRANT_VECTOR_DIMENSION=768

# ── Required: LLM (Ollama) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSION=768
OLLAMA_REQUEST_TIMEOUT=120s

# ── Optional: Neo4j Graph Database ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me

# ── Optional: OpenAI (alternative LLM provider) ──
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── AI Pipeline Configuration ──
AI_MAX_EVIDENCE_SOURCES=4
AI_MAX_PARAGRAPHS=3
AI_MAX_PROMPT_LENGTH=3800
AI_MAX_EXCERPT_LENGTH=500
AI_RETRY_ENABLED=false
AI_COVERAGE_THRESHOLD=0.6
AI_DOMAIN_BOOST=0.35
AI_MAX_MISMATCHED_DOCS=0

# ── Search Configuration ──
CHUNKING_MAX_SIZE=500
CHUNKING_OVERLAP=50
CHUNKING_STRATEGY=SENTENCE
RETRIEVAL_KEYWORD_WEIGHT=0.40
RETRIEVAL_VECTOR_WEIGHT=0.40
RETRIEVAL_CONFIDENCE_WEIGHT=0.20

# ── TLS (production only) ──
# SERVER_SSL_ENABLED=true
# SERVER_SSL_KEY_STORE=classpath:keystore.p12
# SERVER_SSL_KEY_STORE_PASSWORD=change-me
# SERVER_SSL_KEY_ALIAS=mda
